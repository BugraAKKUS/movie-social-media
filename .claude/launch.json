{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@cinesocial/web", "dev"],
      "port": 3000
    },
    {
      "name": "mobile",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@cinesocial/mobile", "dev"],
      "port": 8081
    },
    {
      "name": "api",
      "runtimeExecutable": "services/api/.venv/bin/python",
      "runtimeArgs": ["-m", "uvicorn", "app.main:app", "--reload", "--host", "0.0.0.0", "--port", "8000", "--app-dir", "services/api"],
      "port": 8000
    }
  ]
}
