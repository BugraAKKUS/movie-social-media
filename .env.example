# CineSocial Environment Configuration

# Backend
DATABASE_URL=sqlite+aiosqlite:///./cinesocial.db
SECRET_KEY=change-me-to-a-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# TMDB API (for movie data)
TMDB_API_KEY=your-tmdb-api-key

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=cinesocial-dev

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Redis (for task queue in prod)
REDIS_URL=redis://localhost:6379/0

# ML
ML_DEVICE=cpu
SPOILER_MODEL_PATH=services/ml/model_registry/spoiler_classifier
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
